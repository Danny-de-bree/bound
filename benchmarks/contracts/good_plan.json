{
  "goal": "Ship a JSON parser library",
  "steps": [
    {
      "id": "write-parser",
      "description": "Add a JSON parser with an AST output",
      "goal": "Parse valid JSON into an AST and reject invalid JSON",
      "acceptance_checks": [
        {
          "id": "parser_returns_ast",
          "description": "parse() returns an AST node tree for valid JSON input",
          "required": true
        },
        {
          "id": "parser_raises_on_invalid",
          "description": "parse() raises ParseError for malformed JSON",
          "required": true
        },
        {
          "id": "parser_handles_empty_object",
          "description": "parse('{}') returns an empty-object AST node",
          "required": true
        }
      ],
      "risk_checks": [
        {
          "id": "no_plaintext_secrets",
          "description": "No plaintext secrets introduced in source",
          "severity": 0.9
        },
        {
          "id": "no_panic_on_bad_input",
          "description": "Parser must not panic on malformed input",
          "severity": 0.7
        }
      ],
      "expected_artifacts": [
        "src/parser.py",
        "tests/test_parser.py"
      ],
      "budget": {
        "max_retries": 2,
        "max_tool_calls": 20,
        "max_tokens": 8000,
        "max_runtime_seconds": 120.0
      }
    }
  ]
}